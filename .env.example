# ─── Umum ───
NODE_ENV=development

# Renderda PORT avtomatik beriladi — lokal uchun:
PORT=3000
HOST=0.0.0.0

# ─── MongoDB (Atlas) ───
# .env.example dagi "xxxxx" — FAQAT namuna. Atlas → Database → Connect → Drivers :
# URI ni tugmasidan NUSXA oling (o‘zingizni cluster0.ABCXY.mongodb.net kabi hostname).
# Railway: mongodb.railway.internal Render’da ishlamaydi → Atlas `mongodb+srv` ishlating.
MONGODB_URI=mongodb+srv://USER:ENCODED_PASSWORD@cluster0.REALHOST.mongodb.net/rivoq?retryWrites=true&w=majority

# ─── JWT & session (production’da kuchli, tasodifiy qatorlar) ───
JWT_SECRET=change_me_long_random_string
JWT_EXPIRES_IN=7d
SESSION_SECRET=change_me_another_long_random_secret

# ─── AdminJS / admin panel ───
# Dashboard paroli (kirish uchun email bilan birga soraydi)
ADMIN_PANEL_PASSWORD=123123
# AdminJS sessiya cookie shifrlash kaliti (yangi yarating!)
ADMIN_COOKIE_PASSWORD=change_adminjs_cookie_encryption_secret_long
# DB’da asosiy admin email (bundan foydalanuvchini role=admin bilan ta’minlash)
ADMIN_EMAIL=admin@rivoq.com
# Admin panel sidebar/login: doim «RIVOQ-TEST» (setup.js branding). Quyidagilar ishlatilmaydi:
# ADMIN_BRAND_NAME=RIVOQ-TEST
# ADMIN_BRAND_LOGO=

# Eski README’dagi ADMIN_PASSWORD kerak bo‘lsa (boshqa skriptlar) — asosiy kirish ADMIN_PANEL_PASSWORD
ADMIN_PASSWORD=

# ─── CORS (mobil/veb uchun agar credential kerak bo‘lsa ma’lum domain) ───
# Credentials bilan * ishlamaydi — kerak bo‘lsa: https://sizning-frontend.vercel.app
CORS_ORIGIN=*
CORS_CREDENTIALS=false

# ─── Google OAuth ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ─── Mobil ilova OAuth redirect ───
# APP_REDIRECT_SCHEMES=rivoq://,exp://
# APP_DEFAULT_REDIRECT_URI=

# ─── Email OTP (6 xonali kod) — Gmail misol ───
# Google hisobda 2FA yoqilgan bo‘lsa: Google Account → Security → App passwords → SMTP uchun parol yarating.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=sizning@gmail.com
# SMTP_PASS=16_xonali_app_password
# EMAIL_FROM=RIVIQ <sizning@gmail.com>
# Renderda Gmail IPv6 → ENETUNREACH bo‘lsa: default IPv4 DNS (SMTP_FORCE_IPV4=false qilib o‘chirish mumkin)
SMTP_FORCE_IPV4=true
#
# SMTP bo‘lmasa:
# - NODE_ENV=development bo‘lsa kod server terminalida [OTP] qatori bilan chiqadi.
# - NODE_ENV=production + lokal test: ALLOW_OTP_WITHOUT_SMTP=true (faqat ishchi mashinada; internetga ochiq prod da ishlatmang!)
# ALLOW_OTP_WITHOUT_SMTP=false

# ─── Mobil profil rasmi ───
# `/api/profile/me/avatar` (POST, multipart): maydon nomi avatar | file | photo
# PATCH /profile/me bilan JSON—da `avatar` uchun tashqi HTTPS URL yoki `data:image/jpeg;base64,...` ham mumkin.

# ─── Groq (AI) ───
# GROQ_API_KEY=
# GROQ_MODEL=
